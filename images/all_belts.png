<header class="flex flex-col md:flex-row justify-between items-end mb-8 border-b border-zinc-800 pb-6 gap-4">
    <div class="flex items-center gap-4">
        <div class="relative flex items-center justify-center w-14 h-14 bg-gradient-to-br from-red-600 to-red-900 rounded-xl border-2 border-red-500 shadow-[0_0_20px_rgba(220,38,38,0.4)] transform -rotate-6">
            <span class="text-white font-black text-3xl italic tracking-tighter">N</span>
        </div>
        <div>
            <h1 class="text-4xl font-black italic uppercase tracking-tighter">NiiALL'S <span class="text-red-600">TRACKER</span></h1>
            <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest mt-1">Fan-Made Watch Party Hub</p>
        </div>
    </div>
    <div class="text-right">
        <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest flex items-center justify-end gap-2">
            <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span> Firebase Live Sync
        </p>
        <p class="text-xl font-black italic text-red-600 tracking-tighter mt-1">LAS VEGAS • APR 18</p>
    </div>
</header>

<section class="mb-10 text-center bg-zinc-950/50 p-6 rounded-3xl border border-zinc-800 shadow-2xl">
    <img src="images/all_belts.png" alt="WWE Championship Collection" class="h-28 md:h-32 object-contain mx-auto belt-glow">
    <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest mt-4">NiiALL'S COMPLETE CHAMPIONSHIP COLLECTION</p>
</section>
